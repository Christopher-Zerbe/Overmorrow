# Copy this file to `.env` and fill in real values before running `docker compose up`.
# Do NOT commit your `.env` file.

# WeatherAPI.com — https://www.weatherapi.com
WAPI_KEY=your_weatherapi_key_here

# Unsplash — https://unsplash.com/developers (optional)
UNSPLASH_KEY=your_unsplash_access_key_here

# TimezoneDB — https://timezonedb.com (optional)
TIMEZONEDB_KEY=your_timezonedb_key_here
